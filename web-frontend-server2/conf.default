server {
  listen 80;
  server_name _;
  root /usr/share/nginx/html;
  index index.html;

  location / {
    try_files $uri $uri/ =404;
  }

  location ^~ /blog/ {
    alias /usr/share/nginx/html/blog/;
    index index.html;
    autoindex off;
    try_files $uri $uri/ =404;
  }

  location ~* \.(css|js|png|jpg|gif|ico|svg)$ {
    expires 1d;
    add_header Cache-Control "public";
  }
}
